# =========================
# Root .gitignore
# CipherNotes
# =========================

# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Build outputs
dist/
build/
frontend/dist/
backend/dist/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.*
frontend/.env
frontend/.env.*
backend/.env
backend/.env.*

# OS files
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Coverage
coverage/
.nyc_output/

# Temp files
tmp/
temp/
*.tmp

# Cache
.cache/
.parcel-cache/

# Vite
vite.config.timestamp-*

# Optional lockfiles you may ignore only if you want
# package-lock.json
# yarn.lock
# pnpm-lock.yaml